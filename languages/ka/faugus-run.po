#: /usr/bin/faugus-run:106
msgid "Starting Steam game..."
msgstr "Steam-ის თამაშის გაშვება..."

#: /usr/bin/faugus-run:318
msgid "Are you enjoying Faugus Launcher?"
msgstr "მოგწონთ Faugus Launcher?"

#: /usr/bin/faugus-run:322
msgid "Please consider donating"
msgstr "იფიქრეთ, შემოგვწიროთ"

#: /usr/bin/faugus-run:334
msgid "Never show this message again"
msgstr "აღარ მაჩვენო ეს შეტყობინება"

#: /usr/bin/faugus-run:344
msgid "Continue"
msgstr "გაგრძელება"

#: /usr/bin/faugus-run:392
msgid "Internet connection error."
msgstr "ინტერნეტთან დაკავშირების შეცდომა."

#: /usr/bin/faugus-run:396
#, python-format
msgid "%s was not found."
msgstr "%s აღმოჩენილი არაა."

#: /usr/bin/faugus-run:400
msgid "Please install it or use another Proton version."
msgstr "დააყენეთ ის, ან გამოიყენეთ Proton-ის სხვა ვერსია."

#: /usr/bin/faugus-run:407 /usr/bin/faugus-run:683
msgid "Ok"
msgstr "დიახ"

#: /usr/bin/faugus-run:584
msgid "Updating UMU-Launcher..."
msgstr "UMU-Launcher-ის განახლება..."

#: /usr/bin/faugus-run:586
msgid "UMU-Launcher is up to date"
msgstr "UMU-Launcher განახლებულია"

#: /usr/bin/faugus-run:588
msgid "Updating BattlEye..."
msgstr "BattlEye-ის განახლება..."

#: /usr/bin/faugus-run:590
msgid "Updating Easy Anti-Cheat..."
msgstr "Easy Anti-Cheat-ის განახლება..."

#: /usr/bin/faugus-run:592
msgid "Components are up to date"
msgstr "კომპონენტები განახლებულია"

#: /usr/bin/faugus-run:594
msgid "Downloading UMU-Proton..."
msgstr "UMU-Proton-ის გადმოწერა..."

#: /usr/bin/faugus-run:596
msgid "Downloading Steam Runtime..."
msgstr "Steam-ის გაშვების გარემოს გადმოწერა..."

#: /usr/bin/faugus-run:598
msgid "Extracting Steam Runtime..."
msgstr "Steam-ის გაშვების გარემოს გაშლა..."

#: /usr/bin/faugus-run:600
msgid "Extracting UMU-Proton..."
msgstr "UMU-Proton-ის გაშლა..."

#: /usr/bin/faugus-run:602 /usr/bin/faugus-run:608
msgid "UMU-Proton is up to date"
msgstr "UMU-Proton განახლებულია"

#: /usr/bin/faugus-run:604 /usr/bin/faugus-run:610
msgid "Steam Runtime is up to date"
msgstr "Steam-ის გაშვების გარემო განახლებულია"

#: /usr/bin/faugus-run:606 /usr/bin/faugus-run:617
msgid "GE-Proton is up to date"
msgstr "GE-Proton განახლებულია"

#: /usr/bin/faugus-run:613
msgid "Downloading GE-Proton..."
msgstr "GE-Proton-ის გადმოწერა..."

#: /usr/bin/faugus-run:615
msgid "Extracting GE-Proton..."
msgstr "GE-Proton-ის გაშლა..."

#: /usr/bin/faugus-run:619
msgid "Downloading Proton-EM..."
msgstr "Proton-EM-ის გადმოწერა..."

#: /usr/bin/faugus-run:621
msgid "Extracting Proton-EM..."
msgstr "Proton-EM-ის გაშლა..."

#: /usr/bin/faugus-run:623
msgid "Proton-EM is up to date"
msgstr "Proton-EM განახლებულია"

#: /usr/bin/faugus-run:680
msgid "The keys and values were successfully added to the registry."
msgstr "გასაღებები და მნიშვნელობები წარმატებით დაემატა რეესტრს."
